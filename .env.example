# Required for AI analysis. The OpenAI SDK reads this automatically.
OPENAI_API_KEY=your_api_key_here

# Override when you want to use a different model.
OPENAI_MODEL=gpt-5.2

# Application settings.
APP_DATABASE_PATH=data/jobs_ai.sqlite3
APP_RESUME_PATH=data/resume.md
APP_CV_DIRECTORY=/documents/cv
APP_REQUIRE_MANUAL_REVIEW=true
APP_AUTO_SUBMIT_ENABLED=false

# Search preferences.
JOB_SEARCH_QUERY=python backend engineer remote Spain Madrid Bilbao Valladolid Burgos
JOB_SEARCH_LOCATION=Spain
JOB_SEARCH_LIMIT=25
